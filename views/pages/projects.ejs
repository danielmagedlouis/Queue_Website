<section class="page-hero">
  <div class="max-w-6xl mx-auto">
    <h1>Our Projects</h1>
    <p>Showcase of our best work and client successes.</p>
  </div>
</section>

<section class="section">
  <div class="max-w-6xl mx-auto">
    <div style="display: flex; flex-wrap: wrap; justify-content: center; gap: 1rem; margin-bottom: 3rem;">
      <button style="padding: 0.75rem 1.5rem; border-radius: 9999px; background: linear-gradient(90deg, #7c3aed 0%, #06b6d4 100%); border: none; color: #fff; font-weight: 600; cursor: pointer; transition: all 0.3s;">All</button>
      <button style="padding: 0.75rem 1.5rem; border-radius: 9999px; background: rgba(15, 23, 42, 0.4); border: 1px solid rgba(124, 58, 237, 0.3); color: #fff; font-weight: 600; cursor: pointer; transition: all 0.3s;" onmouseover="this.borderColor='rgba(124, 58, 237, 0.6)'" onmouseout="this.borderColor='rgba(124, 58, 237, 0.3)'">Websites</button>
      <button style="padding: 0.75rem 1.5rem; border-radius: 9999px; background: rgba(15, 23, 42, 0.4); border: 1px solid rgba(124, 58, 237, 0.3); color: #fff; font-weight: 600; cursor: pointer; transition: all 0.3s;" onmouseover="this.borderColor='rgba(124, 58, 237, 0.6)'" onmouseout="this.borderColor='rgba(124, 58, 237, 0.3)'">Systems</button>
      <button style="padding: 0.75rem 1.5rem; border-radius: 9999px; background: rgba(15, 23, 42, 0.4); border: 1px solid rgba(124, 58, 237, 0.3); color: #fff; font-weight: 600; cursor: pointer; transition: all 0.3s;" onmouseover="this.borderColor='rgba(124, 58, 237, 0.6)'" onmouseout="this.borderColor='rgba(124, 58, 237, 0.3)'">Mobile Apps</button>
      <button style="padding: 0.75rem 1.5rem; border-radius: 9999px; background: rgba(15, 23, 42, 0.4); border: 1px solid rgba(124, 58, 237, 0.3); color: #fff; font-weight: 600; cursor: pointer; transition: all 0.3s;" onmouseover="this.borderColor='rgba(124, 58, 237, 0.6)'" onmouseout="this.borderColor='rgba(124, 58, 237, 0.3)'">AI Solutions</button>
    </div>
  </div>
</section>

<section class="section">
  <div class="max-w-6xl mx-auto">
    <div class="project-grid">
      <% projects.forEach(project => { %>
        <div class="project-card">
          <div class="project-card-content">
            <p class="category"><%= project.category %></p>
            <h3><%= project.title %></h3>
            <p>Delivering innovative solutions tailored to your needs with cutting-edge technology.</p>
            <a href="#" class="btn" style="display: inline-block; margin-top: 1rem;">View Project →</a>
          </div>
        </div>
      <% }); %>

      <div class="project-card">
        <div class="project-card-content">
          <p class="category">Custom Systems</p>
          <h3>E-Commerce Platform</h3>
          <p>A complete end-to-end e-commerce solution with payment integration and inventory management.</p>
          <a href="#" class="btn" style="display: inline-block; margin-top: 1rem;">View Project →</a>
        </div>
      </div>

      <div class="project-card">
        <div class="project-card-content">
          <p class="category">AI Solutions</p>
          <h3>Analytics Dashboard</h3>
          <p>Real-time analytics dashboard with predictive insights powered by machine learning algorithms.</p>
          <a href="#" class="btn" style="display: inline-block; margin-top: 1rem;">View Project →</a>
        </div>
      </div>

      <div class="project-card">
        <div class="project-card-content">
          <p class="category">Mobile Applications</p>
          <h3>Fitness Mobile App</h3>
          <p>Cross-platform fitness app with workout tracking, nutrition planning, and social features.</p>
          <a href="#" class="btn" style="display: inline-block; margin-top: 1rem;">View Project →</a>
        </div>
      </div>

      <div class="project-card">
        <div class="project-card-content">
          <p class="category">Website Design</p>
          <h3>SaaS Landing Page</h3>
          <p>High-converting SaaS landing page with interactive demos and optimized conversion funnel.</p>
          <a href="#" class="btn" style="display: inline-block; margin-top: 1rem;">View Project →</a>
        </div>
      </div>

      <div class="project-card">
        <div class="project-card-content">
          <p class="category">AI Solutions</p>
          <h3>Chatbot Automation</h3>
          <p>Intelligent chatbot system with NLP integration for 24/7 customer support automation.</p>
          <a href="#" class="btn" style="display: inline-block; margin-top: 1rem;">View Project →</a>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="section" style="text-align: center;">
  <div class="max-w-4xl mx-auto">
    <h2>Your Next Success Story Awaits</h2>
    <p style="font-size: 1.2rem; color: #d1d5db; margin-bottom: 2rem; max-width: 600px; margin-left: auto; margin-right: auto;">Join dozens of satisfied clients who've transformed their businesses with our solutions.</p>
    <a href="/contact" class="btn" style="display: inline-block;">Start Your Project</a>
  </div>
</section>