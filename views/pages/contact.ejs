<section class="page-hero">
  <div class="max-w-6xl mx-auto">
    <h1>Get In Touch</h1>
    <p>Let's discuss how we can help your business thrive.</p>
  </div>
</section>

<section class="section">
  <div class="max-w-6xl mx-auto">
    <div style="display: grid; grid-template-columns: 1fr 2fr; gap: 3rem; align-items: start;">
      <!-- Contact Info -->
      <div style="display: flex; flex-direction: column; gap: 2rem;">
        <div>
          <h3 style="font-size: 1.5rem; font-weight: 700; margin-bottom: 0.5rem; background: linear-gradient(135deg, #a78bfa 0%, #06b6d4 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">Get In Touch</h3>
          <p style="color: #d1d5db;">Choose your preferred way to reach us</p>
        </div>
        
        <a href="mailto:hello@queuesolutions.com" class="card" style="padding: 1.5rem; text-decoration: none; color: inherit; display: block;">
          <h4 style="font-size: 1.1rem; font-weight: 700; margin-bottom: 0.75rem; color: #a78bfa;">📧 Email</h4>
          <p style="color: #d1d5db; margin: 0;">hello@queuesolutions.com</p>
          <p style="color: #9ca3af; font-size: 0.9rem; margin: 0.5rem 0 0 0;">Response within 24 hours</p>
        </a>

        <a href="tel:+1234567890" class="card" style="padding: 1.5rem; text-decoration: none; color: inherit; display: block;">
          <h4 style="font-size: 1.1rem; font-weight: 700; margin-bottom: 0.75rem; color: #06b6d4;">📞 Phone</h4>
          <p style="color: #d1d5db; margin: 0;">+1 (234) 567-890</p>
          <p style="color: #9ca3af; font-size: 0.9rem; margin: 0.5rem 0 0 0;">Available 9 AM - 6 PM EST</p>
        </a>

        <div class="card" style="padding: 1.5rem;">
          <h4 style="font-size: 1.1rem; font-weight: 700; margin-bottom: 0.75rem; color: #a78bfa;">📍 Address</h4>
          <p style="color: #d1d5db; margin: 0;">Tech Hub, Silicon Valley<br />California, USA</p>
        </div>

        <div class="card" style="padding: 1.5rem; background: linear-gradient(135deg, rgba(124, 58, 237, 0.1) 0%, rgba(6, 182, 212, 0.1) 100%); border: 1.5px solid rgba(124, 58, 237, 0.3);">
          <h4 style="font-size: 1.1rem; font-weight: 700; margin-bottom: 0.75rem; background: linear-gradient(135deg, #a78bfa 0%, #06b6d4 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">⚡ Quick Support</h4>
          <p style="color: #d1d5db; margin: 0;">Chat with us online for instant help</p>
        </div>
      </div>

      <!-- Contact Form -->
      <div>
        <% if (success) { %>
          <div class="success-msg" style="margin-bottom: 2rem; padding: 2rem; background: rgba(34, 197, 94, 0.15); border: 1.5px solid rgba(34, 197, 94, 0.3); border-radius: 1.25rem; animation: scaleIn 0.5s ease-out;">
            <h3 style="font-size: 1.3rem; font-weight: 700; margin-bottom: 0.5rem; color: #86efac;">✓ Thank You!</h3>
            <p style="color: #d1d5db;">We've received your message and will get back to you soon. We appreciate your interest in Queue Solutions!</p>
          </div>
        <% } %>

        <% if (error) { %>
          <div class="error-msg" style="margin-bottom: 2rem; padding: 2rem; background: rgba(239, 68, 68, 0.15); border: 1.5px solid rgba(239, 68, 68, 0.3); border-radius: 1.25rem; animation: scaleIn 0.5s ease-out;">
            <h3 style="font-size: 1.3rem; font-weight: 700; margin-bottom: 0.5rem; color: #fca5a5;">✗ Error</h3>
            <p style="color: #d1d5db;"><%= error %></p>
          </div>
        <% } %>

        <div class="card" style="padding: 2.5rem; background: rgba(15, 23, 42, 0.6);">
          <h3 style="font-size: 1.4rem; font-weight: 700; margin-bottom: 2rem; background: linear-gradient(135deg, #a78bfa 0%, #06b6d4 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">Send us a message</h3>
          
          <form method="POST" action="/contact" class="contact-form">
            <div class="form-group">
              <label for="name" style="color: #f3f4f6;">Full Name *</label>
              <input 
                type="text" 
                id="name" 
                name="name" 
                placeholder="John Doe"
                required
              />
            </div>

            <div class="form-group">
              <label for="email" style="color: #f3f4f6;">Email Address *</label>
              <input 
                type="email" 
                id="email" 
                name="email" 
                placeholder="john@example.com"
                required
              />
            </div>

            <div class="form-group">
              <label for="phone" style="color: #f3f4f6;">Phone Number</label>
              <input 
                type="tel" 
                id="phone" 
                name="phone" 
                placeholder="+1 (234) 567-890"
              />
            </div>

            <div class="form-group">
              <label for="subject" style="color: #f3f4f6;">Subject *</label>
              <input 
                type="text" 
                id="subject" 
                name="subject" 
                placeholder="What is this about?"
                required
              />
            </div>

            <div class="form-group">
              <label for="message" style="color: #f3f4f6;">Message *</label>
              <textarea 
                id="message" 
                name="message" 
                placeholder="Tell us about your project or inquiry..."
                required
              ></textarea>
            </div>

            <button type="submit" class="btn btn-submit" style="width: 100%;">Send Message</button>

            <p style="font-size: 0.9rem; color: #9ca3af; text-align: center; margin-top: 1rem;">* Required fields</p>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- FAQ Section -->
<section class="section">
  <div class="max-w-4xl mx-auto">
    <h2 style="background: linear-gradient(135deg, #a78bfa 0%, #06b6d4 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">Frequently Asked Questions</h2>
    <div class="faq">
      <details class="faq-item" style="margin-bottom: 1.5rem;">
        <summary style="padding: 1.5rem; background: rgba(124, 58, 237, 0.1); border: 1px solid rgba(124, 58, 237, 0.3); border-radius: 0.875rem; cursor: pointer; font-weight: 600; color: #a78bfa; user-select: none; transition: all 0.3s;">What's your typical project timeline?</summary>
        <p style="padding: 1rem 1.5rem; color: #d1d5db; margin-top: 0.5rem;">Most projects take 4-12 weeks depending on complexity. We'll provide a detailed timeline after the discovery phase.</p>
      </details>

      <details class="faq-item" style="margin-bottom: 1.5rem;">
        <summary style="padding: 1.5rem; background: rgba(124, 58, 237, 0.1); border: 1px solid rgba(124, 58, 237, 0.3); border-radius: 0.875rem; cursor: pointer; font-weight: 600; color: #a78bfa; user-select: none; transition: all 0.3s;">Do you provide ongoing support?</summary>
        <p style="padding: 1rem 1.5rem; color: #d1d5db; margin-top: 0.5rem;">Yes! We offer various support packages including maintenance, updates, and 24/7 monitoring.</p>
      </details>

      <details class="faq-item" style="margin-bottom: 1.5rem;">
        <summary style="padding: 1.5rem; background: rgba(124, 58, 237, 0.1); border: 1px solid rgba(124, 58, 237, 0.3); border-radius: 0.875rem; cursor: pointer; font-weight: 600; color: #a78bfa; user-select: none; transition: all 0.3s;">What's your development process?</summary>
        <p style="padding: 1rem 1.5rem; color: #d1d5db; margin-top: 0.5rem;">We follow an agile methodology with regular check-ins, demos, and feedback loops to ensure we're aligned with your vision.</p>
      </details>

      <details class="faq-item" style="margin-bottom: 1.5rem;">
        <summary style="padding: 1.5rem; background: rgba(124, 58, 237, 0.1); border: 1px solid rgba(124, 58, 237, 0.3); border-radius: 0.875rem; cursor: pointer; font-weight: 600; color: #a78bfa; user-select: none; transition: all 0.3s;">Can you work with our existing systems?</summary>
        <p style="padding: 1rem 1.5rem; color: #d1d5db; margin-top: 0.5rem;">Absolutely! We specialize in integrating with legacy systems and modern platforms alike.</p>
      </details>

      <details class="faq-item">
        <summary style="padding: 1.5rem; background: rgba(124, 58, 237, 0.1); border: 1px solid rgba(124, 58, 237, 0.3); border-radius: 0.875rem; cursor: pointer; font-weight: 600; color: #a78bfa; user-select: none; transition: all 0.3s;">How much does a typical project cost?</summary>
        <p style="padding: 1rem 1.5rem; color: #d1d5db; margin-top: 0.5rem;">Pricing varies based on project scope and requirements. Contact us for a custom quote tailored to your needs.</p>
      </details>
    </div>
  </div>
</section>