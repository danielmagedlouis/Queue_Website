{
  "name": "queue-solutions-website",
  "version": "1.0.0",
  "description": "Production-ready company website for Queue Solutions built with Node.js, Express, and Tailwind CSS",
  "main": "app.js",
  "scripts": {
    "start": "npm run build:css && node app.js",
    "dev": "concurrently \"npm run watch:css\" \"nodemon app.js\"",
    "build:css": "tailwindcss -i ./public/css/input.css -o ./public/css/styles.css",
    "watch:css": "tailwindcss -i ./public/css/input.css -o ./public/css/styles.css --watch"
  },
  "author": "Queue Solutions",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.4.0",
    "body-parser": "^1.20.2",
    "cookie-parser": "^1.4.6",
    "ejs": "^3.1.9",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.14",
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.1",
    "postcss": "^8.4.24",
    "tailwindcss": "^3.4.8"
  }
}
